<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_voxbi_installer_setup_form" model="ir.ui.view">
        <field name="name">voxbi.installer.setup.form</field>
        <field name="model">voxbi.installer.setup</field>
        <field name="arch" type="xml">
            <form string="Voxbi Setup" create="false" delete="false" duplicate="false">
                <header>
                    <button name="action_install"
                            string="Install"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_install"
                            string="Re-install"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'done'"/>
                    <button name="action_install"
                            string="Try again"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'failed'"/>
                    <button name="action_retry_with_fresh_credentials"
                            string="Retry with refreshed credentials"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'failed' or not token_id"/>
                    <button name="action_reset"
                            string="Try again with a new token"
                            type="object"
                            class="btn-secondary"
                            invisible="1"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,installing,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1 style="color:#8D3D8A;">Set up Voxbi telephony in Odoo</h1>
                    </div>
                    <div class="alert alert-info" role="alert"
                         invisible="state in ('installing','done')">
                        <h4 class="alert-heading">Get your Cockpit token</h4>
                        <p class="mb-1">In <b>Voxbi Cockpit</b>, generate a single-use install token:</p>
                        <ol class="mb-0">
                            <li>Go to <a href="https://cockpit.voxbi.com/admin/integration/create" target="_blank" rel="noopener">cockpit.voxbi.com/admin/integration/create</a>.</li>
                            <li>Select <b>Odoo Installer</b> as the integration type.</li>
                            <li>Click <b>Generate install token</b> and copy the <code>vxi_…</code> token — it is shown only once.</li>
                        </ol>
                    </div>
                    <group>
                        <field name="install_token"
                               string="Cockpit token"
                               widget="masked_input"
                               placeholder="vxi_…"
                               readonly="state == 'installing'"/>
                    </group>
                    <p class="text-muted" invisible="state in ('installing','done')">
                        Paste the token from Voxbi Cockpit above. If the token has already been used, go back to Cockpit and click <b>Regenerate token</b>.
                    </p>
                    <div class="alert alert-info" role="alert"
                         invisible="state in ('installing','done')">
                        <h4 class="alert-heading">Data shared with Voxbi Cockpit</h4>
                        <p>
                            Installing generates an Odoo API key for your user and sends it —
                            together with this instance's URL, database name, version and your
                            login — to Voxbi Cockpit over HTTPS, so it can configure the Voxbi
                            integration over XML-RPC. You retain ownership of your data and can
                            revoke the key at any time from <b>Preferences → Account Security</b>.
                        </p>
                    </div>
                    <div class="d-flex align-items-center gap-2 mb-3"
                         invisible="state in ('installing','done')">
                        <field name="consent" nolabel="1"/>
                        <label for="consent" class="o_form_label m-0">I authorize Voxbi to configure this Odoo</label>
                    </div>
                    <div class="alert alert-danger" role="alert" invisible="state != 'failed'">
                        <h4 class="alert-heading">Install failed</h4>
                        <field name="message" readonly="1" nolabel="1"/>
                    </div>
                    <widget name="voxbi_auto_refresh"/>
                    <group string="Status" invisible="not token_id">
                        <field name="token_id" widget="masked_text" readonly="1"/>
                        <field name="integration_id" widget="masked_text" readonly="1"/>
                        <field name="message" readonly="1" invisible="state == 'failed'"/>
                    </group>
                    <group string="Output" invisible="not output_html">
                        <field name="output_html" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_voxbi_installer_open" model="ir.actions.server">
        <field name="name">Voxbi Setup</field>
        <field name="model_id" ref="model_voxbi_installer_setup"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_setup()</field>
    </record>

</odoo>
